*.sh text eol=lf
*.kt text eol=lf
*.dart text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.bat text eol=crlf
*.png binary
*.ttf binary
*.jar binary

# H
ios/** linguist-generated=true
linux/** linguist-generated=true
macos/** linguist-generated=true
windows/** linguist-generated=true
web/** linguist-generated=true

# Hide most Android generated files, but keep Kotlin visible
android/** linguist-generated=true
android/**/*.kt linguist-generated=false
android/**/*.kts linguist-generated=false

# Keep main Flutter source visible
lib/** linguist-generated=false
test/** linguist-generated=false
pubspec.yaml linguist-generated=false
